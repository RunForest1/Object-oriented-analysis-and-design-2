# ==========================================
# Visual Studio / C++ Ignore Rules
# ==========================================

# --- Папки сборки и отладки (Debug/Release) ---
# Эти папки содержат скомпилированные .exe и .dll, они не нужны в репозитории
[Dd]ebug/
[Rr]elease/
x64/
Win32/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# --- Файлы пользователя и настройки IDE (.vs) ---
# Самая важная часть! Сюда входят кэши IntelliSense (.ipch), которые весят по 100МБ+
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# --- Файлы компилятора и линковщика (временные) ---
# Они генерируются при каждой сборке и занимают много места
*.aps
*.cachefile
*.deps
*.dll
*.exe
*.exp
*.idb
*.ilk
*.ipch
*.lastbuildstate
*.lib
*.log
*.manifest
*.meta
*.ncb
*.obj
*.pch
*.pdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tlog
*.wrn

# --- Файлы решений и проектов (пользовательские) ---
# Оставляем .sln и .vcxproj, но игнорируем личные настройки
*.opensdf
*.opendb
*.VC.db
*.VC.VC.db
*.cache
*.testlog

# --- Системные файлы ОС ---
.DS_Store
Thumbs.db

# ==========================================
# Что ОСТАЕТСЯ в репозитории (это нужно коммитить):
# ==========================================
# *.cpp, *.h, *.hpp (Исходный код)
# *.sln (Файл решения)
# *.vcxproj, *.filters (Файлы проектов)
# *.rc, *.h (Ресурсы и диалоги)
# README.md, .gitignore